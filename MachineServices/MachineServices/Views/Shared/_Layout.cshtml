<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ООО СтанкоСтрой - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-menu">
            <a href="/" class="nav-link">Главная</a>
            <a href="/Home/About" class="nav-link">О компании</a>
            <a href="/Services" class="nav-link">Список услуг</a>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <a href="/Account/Profile" class="nav-link">Личный кабинет</a>
                <a href="/Account/Logout" class="nav-link">Выйти</a>
            }
            else
            {
                <a href="/Account/Login" class="nav-link">Вход</a>
            }
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="footer-container">
            <p>&copy; 2026 ООО СтанкоСтрой. Все права защищены.</p>
            <p>г. Москва, ул. Станкостроительная, д. 15</p>
        </div>
    </footer>
</body>
</html>