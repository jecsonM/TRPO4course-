<UserControl x:Class="WpfAppWorkStations.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список заказов -->
        <Border Grid.Column="0" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Список заказов" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1" 
                                Command="{Binding FullRefreshCommand}"
                                Content="🔄 Обновить"/>

                        <Button Grid.Column="1" 
                                Grid.Row="1"
                                Command="{Binding AddNewOrderCommand}"
                                Content="➕ Добавить"/>
                    </Grid>
                </Border>

                <!-- Список заказов -->
                <ListBox 
                    Grid.Row="1" 
                    ItemsSource="{Binding OrdersViewModels}"
                    SelectedItem="{Binding CurrentlySelectedOrder}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    HorizontalContentAlignment="Stretch"
                    Background="{StaticResource LightBackBrush}">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" 
                                               Grid.Column="0" 
                                               Text=" #"/>
                                    <TextBlock Grid.Row="0" 
                                               Grid.Column="1" 
                                               Text="{Binding Order.OrderId}"/>

                                    <TextBlock Grid.Row="1" 
                                               Grid.Column="0" 
                                               Text="📅 "/>
                                    <TextBlock Grid.Row="1" 
                                               Grid.Column="1" 
                                               Text="{Binding Order.CreationDate, StringFormat='dd.MM.yyyy HH:mm'}"/>

                                    <TextBlock Grid.Row="2" 
                                               Grid.Column="0" 
                                               Text="🔧"/>
                                    <TextBlock Grid.Row="2" 
                                               Grid.Column="1" 
                                               Text="{Binding Order.Request.ServiceAddress}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Правая панель: детальная информация -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource MainBackBrush}">
            <Border Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentlySelectedOrder.Order.OrderId, StringFormat='Детальная информация о заказе # {0}'}" 
                                       FontSize="18" 
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <!-- Форма редактирования -->
                    <Grid Grid.Row="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0">
                                <StackPanel>
                                    <TextBlock Text="Дата создания"/>
                                    <DatePicker SelectedDate="{Binding CurrentlySelectedOrder.Order.CreationDate}"
                                                IsEnabled="{Binding CurrentlySelectedOrder.IsChanged}"/>

                                    <TextBlock Text="Связанная заявка"/>
                                    <ComboBox ItemsSource="{Binding RequestsViewModels}"
                                              SelectedItem="{Binding CurrentlySelectedRequestForOrder}"
                                              DisplayMemberPath="Request.RequestId"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"/>

                                    <Border Padding="15" Margin="0 10 0 0">
                                        <StackPanel>
                                            <TextBlock Text="Информация о состояниях" 
                                                       Margin="0,0,0,10"/>

                                            <ComboBox ItemsSource="{Binding OrderStates}"
                                                      SelectedItem="{Binding CurrentlySelectedOrderState}"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="True"/>

                                            <Button Command="{Binding AddOrderStateCommand}"
                                                     Content="➕ установить состояние"
                                                     HorizontalAlignment="Right"/>

                                            <ListBox ItemsSource="{Binding RelevantOrderStates}" 
                                                     MinHeight="50">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                                            <TextBlock Text="{Binding RelevantOrderState.SetDate, StringFormat='dd.MM.yyyy'}"/>
                                                            <TextBlock Text="{Binding RelevantOrderState.OrderState.OrderStateName}" Margin="10,0,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="15" Margin="0 10 0 0">
                                        <StackPanel>
                                            <TextBlock Text="Информация о оборудовании" 
                   FontSize="14" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"/>

                                            <!-- Список оборудования в заказе -->
                                            <ListBox ItemsSource="{Binding CurrentlySelectedOrder.Order.Machines}" 
                 MinHeight="50"
                 MaxHeight="150">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock FontWeight="Bold" Text="{Binding Model}"/>
                                                                <TextBlock FontSize="11" Foreground="Gray" Text="{Binding SerialNumber}"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                Content="❌"
                                Command="{Binding DataContext.RemoveMachineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="Убрать из заказа"
                                Width="25"
                                Height="25"
                                Margin="5,0,0,0"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <!-- Добавление оборудования -->
                                            <Grid Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <ComboBox Grid.Column="0"
                                                  ItemsSource="{Binding AvailableMachinesForOrder}"
                                                  SelectedItem="{Binding SelectedMachineToAdd}"
                                                  IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      ToolTip="Выберите оборудование для добавления">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Machine.Model}"/>
                                                                <TextBlock FontSize="10" Text="{Binding Machine.SerialNumber}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <Button Grid.Column="1"
                                        Command="{Binding AddMachineCommand}"
                                        Content="➕ добавить"
                                        Margin="5,0,0,0"
                                        IsEnabled="{Binding SelectedMachineToAdd}"/>
                                            </Grid>

                                            <TextBlock FontSize="11"
                                               Margin="0,5,0,0"
                                               Text="{Binding AvailableMachinesForOrder.Count, StringFormat='Доступно оборудования: {0}'}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Padding="15" Margin="0 10 0 0">
                                        <StackPanel>
                                            <TextBlock Text="Информация о услугах" 
                                                       FontSize="14" 
                                                       FontWeight="Bold" 
                                                       Margin="0,0,0,10"/>

                                            <ListBox ItemsSource="{Binding CurrentlySelectedOrder.Order.Serviceprovisions}" 
                                                     MinHeight="50">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,2">
                                                            <TextBlock Text="{Binding Service.ServiceName}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <Button Command="{Binding AddServiceCommand}"
                                                     Content="➕ добавить услугу"
                                                     HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,20,0,0">
                        <Button Command="{Binding SaveChangesCommand}"
                                Content="💾 Сохранить изменения"
                                IsEnabled="{Binding CurrentlySelectedOrder.IsChanged}"/>

                        <Button Command="{Binding CancelChangesCommand}"
                                Content="❌ Отменить изменения"
                                IsEnabled="{Binding CurrentlySelectedOrder.IsChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>