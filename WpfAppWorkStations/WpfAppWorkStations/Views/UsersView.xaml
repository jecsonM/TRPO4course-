<UserControl x:Class="WpfAppWorkStations.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: список пользователей -->
        <Border Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Список пользователей" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1" 
                                Command="{Binding RefreshUsersCommand}"
                                Content="🔄 Обновить"/>
                    </Grid>
                </Border>

                <ListBox 
                    Grid.Row="1" 
                    ItemsSource="{Binding StaffViewModels}"
                    SelectedItem="{Binding CurrentlySelectedStaff}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    HorizontalContentAlignment="Stretch">

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border>
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" 
                                               Grid.Column="0" 
                                               Text="👤 "/>
                                    <TextBlock Grid.Row="0" 
                                               Grid.Column="1" 
                                               Text="{Binding Staff.Login}"
                                               FontWeight="Bold"/>

                                    <TextBlock Grid.Row="1" 
                                               Grid.Column="1" 
                                               Text="{Binding RoleName}"
                                               FontSize="11"
                                               Foreground="Gray"
                                               Margin="0,2,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Правая панель: детальная информация -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{StaticResource MainBackBrush}">
            <Border Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Border Grid.Row="0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentlySelectedStaff.Staff.Login, StringFormat='Пользователь: {0}'}" 
                                       FontSize="18" 
                                       FontWeight="Bold"/>
                            <TextBlock Text="{Binding CurrentlySelectedStaff.RoleName, StringFormat='Роль: {0}'}"
                                       FontSize="14"
                                       Foreground="Gray"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Смена пароля -->
                    <Border Grid.Row="1" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Смена пароля" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Новый пароль" FontSize="11" Foreground="Gray"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <PasswordBox Grid.Column="0" 
                                             PasswordChanged="NewPasswordBox_PasswordChanged"
                                             IsEnabled="{Binding CanChangePassword}"
                                             ToolTip="Введите новый пароль"/>

                                <Button Grid.Column="1"
                                        Command="{Binding SetNewPasswordCommand}"
                                        Content="🔑 Установить пароль"
                                        Margin="10,0,0,0"
                                        IsEnabled="{Binding CanChangePassword}"/>
                            </Grid>

                            <TextBlock FontSize="10" 
                                       Foreground="Orange"
                                       IsEnabled="{Binding CanChangePassword}">
                                
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Создание нового пользователя -->
                    <Border Grid.Row="2" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Создание нового пользователя" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Margin="0,0,0,10"/>

                            <TextBlock Text="Логин" FontSize="11" Foreground="Gray"/>
                            <TextBox Text="{Binding NewUserLogin, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Пароль" FontSize="11" Foreground="Gray"/>
                            <PasswordBox PasswordChanged="NewUserPasswordBox_PasswordChanged"
                                         Margin="0,0,0,10"/>

                            <TextBlock Text="Роль" FontSize="11" Foreground="Gray"/>
                            <ComboBox ItemsSource="{Binding RolesViewModels}"
                                      SelectedItem="{Binding SelectedNewUserRole}"
                                      DisplayMemberPath="Role.RoleName"
                                      Margin="0,0,0,10"/>

                            <Button Command="{Binding AddNewUserCommand}"
                                    Content="➕ Добавить пользователя"
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Удаление пользователя -->
                    <Border Grid.Row="3" Padding="15" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Удаление пользователя" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="Red"
                                       Margin="0,0,0,10"/>

                            <Button Command="{Binding DeleteUserCommand}"
                                    Content="🗑️ Удалить пользователя"
                                    Background="#DC3545"
                                    Foreground="White"
                                    IsEnabled="{Binding CurrentlySelectedStaff}"
                                    HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>