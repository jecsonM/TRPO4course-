<UserControl x:Class="WpfAppWorkStations.Views.RequestsViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfAppWorkStations.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>


                <Border Grid.Row="0" >

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Список заявок" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   VerticalAlignment="Center"/>

                        <Button Grid.Column="1" 
                                Command="{Binding RefreshRequestsCommand}"
                                Content="🔄 Обновить">
                        </Button>

                        <Button Grid.Column="1" 
                                Grid.Row="1"
                            Command="{Binding AddNewRequestCommand}"
                            Content="➕ Добавить">
                        </Button>
                    </Grid>
                </Border>

                <!-- Список заявок -->
                <ListBox 
                    Grid.Row="1" 
                    ItemsSource="{Binding RequestsViewModels}"
                    SelectedItem="{Binding CurrentlySelectedRequest}"
                    Background="{StaticResource LightBackBrush}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    HorizontalContentAlignment="Stretch"
                    >

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource MainBackBrush}" >
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" 
                                       Grid.Column="0" 
                                       Text=" #" />
                                    <TextBlock Grid.Row="0" 
                                       Grid.Column="1" 
                                       Text="{Binding Request.RequestId}" 
                                       />


                                    <TextBlock Grid.Row="1" 
                                               Grid.Column="0" 
                                               Text="📅 " />
                                    <TextBlock Grid.Row="1" 
                                               Grid.Column="1" 
                                               Text="{Binding Request.CreationDate, StringFormat='dd.MM.yyyy HH:mm'}"/>


                                    <TextBlock Grid.Row="2" 
                                               Grid.Column="0" 
                                               Text="📍"/>
                                    <TextBlock Grid.Row="2" 
                                               Grid.Column="1" 
                                               Text="{Binding Request.ServiceAddress}" 
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="3" 
                                               Grid.Column="0" 
                                               Text="🏢"/>
                                    <TextBlock Grid.Row="3" 
                                               Grid.Column="1" 
                                               Text="{Binding Request.Client.CompanyName}"
                                               TextWrapping="Wrap"/>


                                    <TextBlock Grid.Row="4" 
                                               Grid.Column="0" 
                                               Text="🛠️"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding MastersLoginDisplay}"/>


                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>


        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Border Background="{StaticResource MainBackBrush}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <Border Grid.Row="0" Padding="15" Background="{StaticResource LightBackBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentlySelectedRequest.Request.RequestId, StringFormat='Детальная информация о заявке # {0}'}" 
                                       FontSize="18" 
                                       FontWeight="Bold"/>

                            <TextBlock Text="{Binding CurrentlySelectedRequest.Request.ServiceAddress}" 
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>


                    <Grid Grid.Row="1" >

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Форма редактирования -->
                            <Border Grid.Row="0" >
                                <StackPanel>

                                    <TextBlock Text="{Binding CurrentlySelectedRequest.MastersLoginDisplay}"/>
                                    <Button Command="{Binding AddMasterCommand}"
                                            Content="➕ Закрепить себя в заявке"
                                            HorizontalAlignment="Right"
                                            />

                                    <TextBlock Text="Дата создания"/>
                                    <DatePicker SelectedDate="{Binding CurrentlySelectedRequest.Request.CreationDate}"
                                                IsEnabled="{Binding CurrentlySelectedRequest.IsChanged}"/>


                                    <TextBlock Text="Адрес услуги"  />
                                    <TextBox Text="{Binding CurrentlySelectedRequest.Request.ServiceAddress, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"/>
                                    <Border
                                        Padding="15" 
                                        Margin="0 10 0 0">
                                        <StackPanel>
                                            <TextBlock Text="Информация о состояниях" 
                                                       Margin="0,0,0,10"/>

                                            <ListBox ItemsSource="{Binding RelevantRequestStates}" MinHeight="50" Background="Transparent">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                                            <TextBlock Text="{Binding RelevantRequestState.SetDate, StringFormat='dd.MM.yyyy'}"/>
                                                            <TextBlock Text="{Binding RelevantRequestState.RequestState.RequestStateName}" Margin="10,0,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </Border>

                                    <Border
                                            Padding="15" 
                                            Margin="0 10 0 0">
                                        <StackPanel>
                                            <TextBlock Text="Информация о клиенте" 
                                                       FontSize="14" 
                                                       FontWeight="Bold" 
                                                       Margin="0,0,0,10"
                                                       />

                                            <TextBlock Text="Компания"  />
                                            <ComboBox ItemsSource="{Binding ClientViewModels}"
                                              SelectedItem="{Binding CurrentlySelectedClient}"
                                              DisplayMemberPath="Client.CompanyName"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"/>

                                            <TextBlock Text="Контактное лицо" />
                                            <TextBox Text="{Binding CurrentlySelectedRequest.Request.Client.ContactPersonFullname}" 
                                                     IsReadOnly="True"/>

                                            <TextBlock Text="Телефон"  />
                                            <TextBox Text="{Binding CurrentlySelectedRequest.Request.Client.ContactPhone}" 
                                                     IsReadOnly="True"/>

                                            <TextBlock Text="Email"  />
                                            <TextBox Text="{Binding CurrentlySelectedRequest.Request.Client.Email}" 
                                                     IsReadOnly="True"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>


                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Margin="0,20,0,0">

                        <Button Command="{Binding SaveChangesCommand}"
                                Content="💾 Сохранить изменения"
                                IsEnabled="{Binding CurrentlySelectedRequest.IsChanged}">

                        </Button>

                        <Button Command="{Binding CancelChangesCommand}"
                                Content="❌ Отменить изменения"
                                IsEnabled="{Binding CurrentlySelectedRequest.IsChanged}">
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>

</UserControl>
