<Window x:Class="WpfAppWorkStations.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WpfAppWorkStations.ViewModels.Pages"
        xmlns:views="clr-namespace:WpfAppWorkStations.Views"
        xmlns:local="clr-namespace:WpfAppWorkStations"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="800"
        Background="{StaticResource LightBackBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Visibility="{Binding NavPanelVisibility}">
            <Button 
                Content="{Binding MainMenu.PageViewModel.Title}"
                Command="{Binding MainMenu}"
                Margin="5"
                Padding="10,5"
                HorizontalAlignment="Stretch"/>
            <TextBlock Text="{Binding CurrentUserDisplay}" HorizontalAlignment="Right"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.Resources>
                <DataTemplate DataType="{x:Type vm:AuthorizationViewModel }">
                    <views:AuthorizationView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ActivitySelectionViewModel }">
                    <views:ActivitySelectionView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:RequestsViewModel }">
                    <views:RequestsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:OrdersViewModel }">
                    <views:OrdersView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:MachinesViewModel }">
                    <views:MachinesView/>
                </DataTemplate>
            </Grid.Resources>
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
    
    
</Window>
